{
  "name": "@learn-react/react-router-ssr",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typegen:css": "tcm app",
    "typegen:rr": "react-router typegen",
    "lint:oxc": "oxlint --type-aware",
    "lint:es": "eslint",
    "lint:style": "stylelint './**/*.css'",
    "lint": "pnpm lint:oxc && pnpm lint:es && pnpm lint:style",
    "dev:client": "react-router dev",
    "dev": "pnpm typegen:rr --watch & pnpm typegen:css -w & pnpm dev:client & pnpm typecheck --watch",
    "build": "cross-env NODE_ENV=production react-router build",
    "start": "cross-env NODE_ENV=production react-router-serve ./build/server/index.js"
  },
  "dependencies": {
    "@react-router/fs-routes": "8.0.1",
    "@react-router/node": "8.0.1",
    "@react-router/serve": "8.0.1",
    "clsx": "2.1.1",
    "isbot": "5.1.44",
    "match-sorter": "8.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.1",
    "sort-by": "1.2.0",
    "tiny-invariant": "1.3.3"
  },
  "devDependencies": {
    "@learn-react/linter": "workspace:*",
    "@learn-react/tsconfig": "workspace:*",
    "@react-router/dev": "8.0.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sort-by": "1.2.3",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "stylelint": "17.14.0",
    "typed-css-modules": "0.9.1",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  }
}
