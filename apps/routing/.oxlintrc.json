{
  "$schema": "./node_modules/oxlint/configuration_schema.json",

  // eslint.config.js や tsconfig.base.json のようなパス解決ができないため、やむなく相対パスで参照しています。
  "extends": ["./node_modules/@learn-react/linter/.oxlintrc.json"],
  "overrides": [
    {
      "files": ["src/**/*.tsx"],
      "rules": {
        "react/only-export-components": ["off"],
        "typescript/only-throw-error": ["off"]
      }
    }
  ]
}
